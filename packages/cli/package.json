{
  "name": "@plumpslabs/fennec-cli",
  "version": "1.12.2",
  "description": "Fennec CLI — pipe, attach, watch, and start the Fennec MCP server",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cli",
    "browser-automation",
    "developer-tools"
  ],
  "homepage": "https://github.com/plumpslabs/fennec#readme",
  "bugs": {
    "url": "https://github.com/plumpslabs/fennec/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plumpslabs/fennec.git"
  },
  "license": "MIT",
  "author": "Fennec Contributors",
  "type": "module",
  "bin": {
    "fennec": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "node -e \"const{rmSync,existsSync}=require('fs');const d='dist';existsSync(d)&&(console.log('removing',d),rmSync(d,{recursive:true,force:true}))\"",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint: ok'",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@plumpslabs/fennec-core": "workspace:*",
    "picocolors": "^1.1.1"
  },
  "peerDependencies": {
    "playwright": "^1.42.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "cli-table3": "^0.6.5",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
