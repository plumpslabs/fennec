{
  "name": "@plumpslabs/fennec-core",
  "version": "1.8.0",
  "description": "Fennec MCP server — AI-native browser, terminal, and process observability",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "browser-automation",
    "playwright",
    "developer-tools",
    "observability"
  ],
  "homepage": "https://github.com/plumpslabs/fennec#readme",
  "bugs": {      "url": "https://github.com/plumpslabs/fennec/issues"
  },
  "repository": {
    "type": "git",      "url": "git+https://github.com/plumpslabs/fennec.git"
  },
  "license": "MIT",
  "author": "Fennec Contributors",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint: ok'",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chokidar": "^3.6.0",
    "pino": "^8.19.0",
    "playwright": "^1.42.0",
    "zod": "^3.22.0",
    "zod-to-json-schema": "^3.23.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
